<%- include('partials/header') %>

<main class="container">
  <h1>Assign Categories to <%= project.title %></h1>

  <form action="/assign-categories/<%= project.project_id || projectId %>" method="POST">
    <div class="form-group">
      <p>Select all categories that apply to this project:</p>
      
      <div class="checkbox-group">
        <% categories.forEach(category => { %>
          <div class="checkbox-item">
            <label class="checkbox-label">
              <input 
                type="checkbox" 
                name="categories" 
                value="<%= category.category_id %>"
                <%= assignedCategoryIds.includes(category.category_id) ? 'checked' : '' %>
              />
              <%= category.name %>
            </label>
          </div>
        <% }); %>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="button btn-primary">Save Category Assignments</button>
      <a href="/project/<%= project.project_id || projectId %>" class="button btn-secondary">Cancel</a>
    </div>
  </form>
</main>

<%- include('partials/footer') %>