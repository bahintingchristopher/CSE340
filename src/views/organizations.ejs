<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <p>Here are a few of our partner organizations:</p>
        <ul>
<!-- 
            <% organizations.forEach(organization => { %>
                <li><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><strong><%= organization.name %></strong>: <%= organization.contact_email %></li>
            <% }); %> -->

            <% organizations.forEach(organization => { %>
                <li>
                    <!-- 1. The Logo Image -->
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    
                    <!-- 2. The Name as a Link -->
                    <strong>
                        <a href="/organization/<%= organization.organization_id %>">
                            <%= organization.name %>
                        </a>
                    </strong>
                    
                    <!-- 3. The Email -->
                    : <%= organization.contact_email %>
                </li>
            <% }); %>

        </ul>
    </main>

<%- include('partials/footer') %>