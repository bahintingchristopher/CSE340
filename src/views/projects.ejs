<%- include('partials/header') %>

<link rel="stylesheet" href="/css/main.css">

<main>
    <h1><%= title %></h1> 
    <table class="projects-items">
        <thead>
            <tr>
                <th>Date</th>
                <th>Project Title</th>
                <th>Organization Name</th>
            </tr>
        </thead>
        <tbody>
            <% projects.forEach(project => { %>
                <% 
                    const datesetup = { year: 'numeric', month: 'long', day: 'numeric' };
                    const formattedDate = new Date(project.date).toLocaleDateString('en-US', datesetup);
                %>
                <tr>
                    <td><strong><%= formattedDate %></strong></td>
                    
                    <td>
                        <a href="/project/<%= project.project_id %>" class="project-title-link">
                            <%= project.title %>
                        </a>

                        <% if (project.categories && project.categories.length > 0) { %>
                            <div class="table-project-tags">
                                <% project.categories.forEach(cat => { %>
                                    <a href="/category/<%= cat.category_id %>" class="table-tag">
                                        <%= cat.name %>
                                    </a>
                                <% }); %>
                            </div>
                        <% } %>
                    </td>
                    
                    <td>
                        <a href="/organization/<%= project.organization_id %>">
                            <%= project.organization_name %>
                        </a>
                    </td>
                </tr>
            <% }); %>
        </tbody>
    </table>

  <p><a href="/new-project">Add a New Service Project</a></p>
  
</main>

<%- include('partials/footer') %>