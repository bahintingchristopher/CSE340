<%- include('partials/header') %>

<link rel="stylesheet" href="/css/main.css">

<main>
    <h1><%= title %></h1>
    
    <p>Here are the service projects categorized under <strong><%= title %></strong>:</p>

    <% if (projects && projects.length > 0) { %>
        <ul class="category-projects-list">
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>">
                        <%= project.title %>
                    </a>
                    - Located in <%= project.location %>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service projects found in this category yet.</p>
    <% } %>

    <!-- Edit Category Action Button -->
  <% if (typeof category !== 'undefined' && category) { %>
    <div class="actions">
      <a href="/edit-category/<%= category.category_id %>" class="button btn-secondary">Edit Category</a>
    </div>
  <% } %>
</main>

<%- include('partials/footer') %>