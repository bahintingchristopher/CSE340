<%- include('partials/header') %>

<main class="container">
  <h1><%= title %></h1>

  <form action="/edit-project/<%= project.project_id %>" method="POST" class="form-container">
    <div class="form-group">
      <label for="title">Title:</label>
      <input type="text" id="title" name="title" value="<%= project.title %>" required>
    </div>

    <div class="form-group">
      <label for="description">Description:</label>
      <textarea id="description" name="description" required><%= project.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location:</label>
      <input type="text" id="location" name="location" value="<%= project.location %>" required>
    </div>

    <div class="form-group">
      <label for="date">Date</label>
      <input 
        type="date" 
        id="date" 
        name="date" 
        value="<%= project.date ? new Date(project.date).toISOString().split('T')[0] : '' %>" 
        required 
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Partner Organization:</label>
      <!-- FIXED: Changed name to "organizationId" to match body('organizationId') -->
      <select id="organizationId" name="organizationId" required>
        <option value="">-- Select an Organization --</option>
        <% organizations.forEach(org => { %>
          <option 
            value="<%= org.organization_id %>" 
            <%= (org.organization_id == project.organization_id) ? 'selected' : '' %>>
            <%= org.name %>
          </option>
        <% }); %>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="button btn-primary">Update Project</button>
      <a href="/project/<%= project.project_id %>" class="button btn-secondary">Cancel</a>
    </div>
  </form>
</main>

<%- include('partials/footer') %>